    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "chatgpt",
    "mcp",
    "note.com",
    "note-connector",
    "apps-sdk"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drillan/note-mcp.git"
  },
  "homepage": "https://github.com/drillan/note-mcp#readme"
