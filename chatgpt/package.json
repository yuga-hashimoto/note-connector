{
  "name": "note-connector",
  "version": "0.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "ChatGPT Connector for note.com — MCP server with Apps SDK UI. One command setup: uv, Playwright, tunnel.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "note-connector": "dist/bin.js"
  },
  "files": [
